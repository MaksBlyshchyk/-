@{
    ViewData["Title"] = "Access denied";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-warning">
            <div class="card-body p-4">
                <span class="badge text-bg-warning mb-3">403</span>
                <h1 class="h3">Доступ обмежено</h1>
                <p class="text-muted mb-4">Вашій ролі недостатньо прав для цієї операції.</p>
                <a class="btn btn-primary" asp-controller="Home" asp-action="Index">На Dashboard</a>
                <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Logout">Увійти під іншим користувачем</a>
            </div>
        </div>
    </div>
</div>
