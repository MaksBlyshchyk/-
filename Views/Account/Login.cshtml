@model HRReserveSystem.ViewModels.LoginViewModel
@using HRReserveSystem.Models

@{
    ViewData["Title"] = "Вхід";
    var demoUsers = ViewData["DemoUsers"] as IReadOnlyList<Recruiter> ?? [];
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
        <div class="card login-card">
            <div class="card-body p-4">
                <div class="mb-4">
                    <span class="badge text-bg-primary mb-2">HR Reserve System</span>
                    <h1 class="h3 mb-1">Вхід у систему</h1>
                    <p class="text-muted mb-0">Увійдіть, щоб працювати з кадровим резервом.</p>
                </div>

                <form asp-action="Login" method="post" class="row g-3">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="col-12">
                        <label asp-for="Login" class="form-label"></label>
                        <input asp-for="Login" class="form-control form-control-lg" autocomplete="username" />
                        <span asp-validation-for="Login" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control form-control-lg" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary btn-lg w-100">Увійти</button>
                    </div>
                </form>

                <div class="alert alert-light border mt-4 mb-0">
                    <div class="fw-semibold mb-2">Демо-користувачі</div>
                    @foreach (var user in demoUsers)
                    {
                        <div class="small"><code>@user.Login</code> / <code>@user.Password</code> - @user.Role</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
