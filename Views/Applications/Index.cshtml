@model IEnumerable<HRReserveSystem.Models.Application>

@{
    ViewData["Title"] = "Заявки";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <h1 class="h2 mb-0">Заявки</h1>
    <a class="btn btn-primary" asp-action="Create">Створити заявку</a>
</div>

<div class="card">
    <div class="table-responsive">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Кандидат</th>
                <th>Вакансія</th>
                <th>Статус</th>
                <th>Дата подачі</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            var badgeClass = item.Status switch
            {
                "New" => "text-bg-primary",
                "In review" => "text-bg-info",
                "Interview" => "text-bg-warning",
                "Offer" => "text-bg-success",
                "Accepted" => "text-bg-success",
                "Hired" => "text-bg-success",
                "Rejected" => "text-bg-danger",
                _ => "text-bg-secondary"
            };

            <tr>
                <td>@item.Candidate?.FullName</td>
                <td>@item.Vacancy?.Title</td>
                <td><span class="badge @badgeClass">@item.Status</span></td>
                <td>@item.AppliedAt.ToLocalTime().ToString("g")</td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Редагувати</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Деталі</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Видалити</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
</div>
