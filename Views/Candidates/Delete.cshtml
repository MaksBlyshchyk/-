@model Candidate

@{
    ViewData["Title"] = "Видалити кандидата";
}

<h1 class="h2 mb-3">Видалити кандидата</h1>
<div class="alert alert-warning">Підтвердіть видалення кандидата <strong>@Model.FullName</strong>.</div>

<dl class="row">
    <dt class="col-sm-3">Електронна пошта</dt>
    <dd class="col-sm-9">@Model.Email</dd>
    <dt class="col-sm-3">Файл резюме</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.ResumeFilePath) ? "Не додано" : Model.ResumeFilePath)</dd>
    <dt class="col-sm-3">Навички</dt>
    <dd class="col-sm-9">@Model.Skills</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Видалити</button>
    <a class="btn btn-secondary" asp-action="Index">Назад до списку</a>
</form>
