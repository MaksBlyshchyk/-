@model Candidate

@{
    ViewData["Title"] = "Деталі кандидата";
    var averageSoftSkillScore = Model.SoftSkillAssessments.Any()
        ? Math.Round(Model.SoftSkillAssessments.Average(assessment => assessment.AverageScore), 1)
        : (double?)null;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2 mb-0">@Model.FullName</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Редагувати</a>
        <a class="btn btn-secondary" asp-action="Index">Назад до списку</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Електронна пошта</dt>
            <dd class="col-sm-9">@Model.Email</dd>
            <dt class="col-sm-3">Телефон</dt>
            <dd class="col-sm-9">@Model.Phone</dd>
            <dt class="col-sm-3">Навички</dt>
            <dd class="col-sm-9">@Model.Skills</dd>
            <dt class="col-sm-3">Файл резюме</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.ResumeFilePath) ? "Не додано" : Model.ResumeFilePath)</dd>
            <dt class="col-sm-3">Коротке резюме</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.ResumeSummary) ? "Не додано" : Model.ResumeSummary)</dd>
            <dt class="col-sm-3">Досвід</dt>
            <dd class="col-sm-9">@Model.ExperienceYears р.</dd>
            <dt class="col-sm-3">Середній soft skills score</dt>
            <dd class="col-sm-9">
                @if (averageSoftSkillScore.HasValue)
                {
                    <span class="score-badge score-badge-average">@averageSoftSkillScore</span>
                    <span class="text-muted">/ 10</span>
                }
                else
                {
                    <span class="text-muted">Оцінку ще не додано</span>
                }
            </dd>
            <dt class="col-sm-3">Створено</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white">
        <h2 class="h5 mb-0">Заявки кандидата</h2>
    </div>
    @if (Model.Applications.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Вакансія</th>
                        <th>Статус</th>
                        <th>Дата</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var application in Model.Applications)
                {
                    <tr>
                        <td>@application.Vacancy?.Title</td>
                        <td><span class="badge @HrOptions.ApplicationStatusBadge(application.Status)">@application.Status</span></td>
                        <td>@application.AppliedAt.ToLocalTime().ToString("g")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">У кандидата ще немає заявок.</div>
    }
</div>

<div class="card mt-4">
    <div class="card-header bg-white">
        <h2 class="h5 mb-0">Оцінки soft skills</h2>
    </div>
    @if (Model.SoftSkillAssessments.Any())
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Комунікація</th>
                        <th>Команда</th>
                        <th>Відповідальність</th>
                        <th>Стрес</th>
                        <th>Лідерство</th>
                        <th>Середній бал</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var assessment in Model.SoftSkillAssessments)
                {
                    <tr>
                        <td><span class="score-badge">@assessment.Communication</span></td>
                        <td><span class="score-badge">@assessment.Teamwork</span></td>
                        <td><span class="score-badge">@assessment.Responsibility</span></td>
                        <td><span class="score-badge">@assessment.StressResistance</span></td>
                        <td><span class="score-badge">@assessment.Leadership</span></td>
                        <td><span class="score-badge score-badge-average">@assessment.AverageScore</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">Для кандидата ще немає оцінок soft skills.</div>
    }
</div>
