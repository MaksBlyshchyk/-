@model Candidate

@{
    ViewData["Title"] = "Деталі кандидата";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2 mb-0">@Model.FullName</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Редагувати</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
    <dt class="col-sm-3">Телефон</dt>
    <dd class="col-sm-9">@Model.Phone</dd>
    <dt class="col-sm-3">Навички</dt>
    <dd class="col-sm-9">@Model.Skills</dd>
    <dt class="col-sm-3">Досвід</dt>
    <dd class="col-sm-9">@Model.ExperienceYears р.</dd>
    <dt class="col-sm-3">Створено</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>
</dl>

<h2 class="h5 mt-4">Заявки кандидата</h2>
<table class="table table-sm align-middle">
    <thead>
        <tr>
            <th>Вакансія</th>
            <th>Статус</th>
            <th>Дата</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var application in Model.Applications)
    {
        <tr>
            <td>@application.Vacancy?.Title</td>
            <td>@application.Status</td>
            <td>@application.AppliedAt.ToLocalTime().ToString("g")</td>
        </tr>
    }
    </tbody>
</table>
