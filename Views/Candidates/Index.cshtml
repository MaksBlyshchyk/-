@model IEnumerable<Candidate>

@{
    ViewData["Title"] = "Кандидати";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div>
        <h1 class="h2 mb-1">Кандидати</h1>
        <p class="text-muted mb-0">База кадрового резерву з контактами, навичками та досвідом.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-primary" asp-action="ExportCsv" asp-route-search="@ViewData["CurrentFilter"]" asp-route-minExperience="@ViewData["MinExperience"]"><span aria-hidden="true">CSV</span> Експорт</a>
        <a class="btn btn-success" asp-action="Create"><span aria-hidden="true">+</span> Додати кандидата</a>
    </div>
</div>

<form asp-action="Index" method="get" class="card mb-3">
    <div class="card-body row g-3 align-items-end">
        <div class="col-lg-6">
            <label class="form-label" for="candidateSearch">Пошук</label>
            <input id="candidateSearch" class="form-control" type="search" name="search" value="@ViewData["CurrentFilter"]" placeholder="ПІБ, email або навички" />
        </div>
        <div class="col-sm-6 col-lg-3">
            <label class="form-label" for="minExperience">Мінімальний досвід</label>
            <input id="minExperience" class="form-control" type="number" min="0" name="minExperience" value="@ViewData["MinExperience"]" placeholder="0" />
        </div>
        <div class="col-sm-6 col-lg-3 d-flex gap-2">
            <button class="btn btn-outline-primary flex-fill" type="submit">Фільтрувати</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Скинути</a>
        </div>
    </div>
</form>

<div class="card">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ПІБ</th>
                        <th>Електронна пошта</th>
                        <th>Телефон</th>
                        <th>Навички</th>
                        <th>Досвід</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.Skills</td>
                        <td><span class="badge text-bg-info text-dark">@item.ExperienceYears р.</span></td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Id"><span aria-hidden="true">E</span> Редагувати</a>
                            <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id"><span aria-hidden="true">i</span> Деталі</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id"><span aria-hidden="true">x</span> Видалити</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h2 class="h5">Дані відсутні</h2>
            <p class="text-muted mb-3">Натисніть кнопку «Додати», щоб створити перший запис.</p>
            <a class="btn btn-success" asp-action="Create"><span aria-hidden="true">+</span> Додати кандидата</a>
        </div>
    }
</div>
