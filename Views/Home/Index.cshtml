@model HRReserveSystem.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-hero d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <span class="badge text-bg-primary mb-2">HR Reserve System</span>
        <h1 class="h2 mb-1">Dashboard кадрового резерву</h1>
        <p class="text-muted mb-0">Огляд кандидатів, вакансій, етапів відбору, співбесід і soft skills для щоденної роботи рекрутера.</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
    {
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-success" asp-controller="Candidates" asp-action="Create"><span aria-hidden="true">+</span> Кандидат</a>
            <a class="btn btn-outline-primary" asp-controller="Vacancies" asp-action="Create"><span aria-hidden="true">+</span> Вакансія</a>
            <a class="btn btn-outline-secondary" asp-controller="Applications" asp-action="Create"><span aria-hidden="true">+</span> Заявка</a>
        </div>
    }
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-xl-2">
        <div class="card dashboard-card h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Кандидати</div>
                <div class="display-6 fw-semibold">@Model.CandidateCount</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-2">
        <div class="card dashboard-card h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Вакансії</div>
                <div class="display-6 fw-semibold">@Model.VacancyCount</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-2">
        <div class="card dashboard-card h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Заявки</div>
                <div class="display-6 fw-semibold">@Model.ApplicationCount</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-2">
        <div class="card dashboard-card h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Співбесіди</div>
                <div class="display-6 fw-semibold">@Model.InterviewCount</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-2">
        <div class="card dashboard-card h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Рекрутери</div>
                <div class="display-6 fw-semibold">@Model.RecruiterCount</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-2">
        <div class="card dashboard-card h-100 border-success-subtle">
            <div class="card-body">
                <div class="text-success small text-uppercase">Прийняті</div>
                <div class="display-6 fw-semibold">@Model.AcceptedCandidateCount</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-2">
        <div class="card dashboard-card h-100 border-danger-subtle">
            <div class="card-body">
                <div class="text-danger small text-uppercase">Відхилені</div>
                <div class="display-6 fw-semibold">@Model.RejectedCandidateCount</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h2 class="h5 mb-0">Останні кандидати</h2>
                @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                {
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Candidates" asp-action="Index">Усі</a>
                }
            </div>
            @if (Model.RecentCandidates.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ПІБ</th>
                                <th>Досвід</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var candidate in Model.RecentCandidates)
                        {
                            <tr>
                                <td>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                                    {
                                        <a asp-controller="Candidates" asp-action="Details" asp-route-id="@candidate.Id">@candidate.FullName</a>
                                    }
                                    else
                                    {
                                        @candidate.FullName
                                    }
                                    <div class="text-muted small">@candidate.Email</div>
                                </td>
                                <td><span class="badge text-bg-info text-dark">@candidate.ExperienceYears р.</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">Кандидатів ще немає.</div>
            }
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h2 class="h5 mb-0">Останні вакансії</h2>
                @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                {
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Vacancies" asp-action="Index">Усі</a>
                }
            </div>
            @if (Model.RecentVacancies.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Назва</th>
                                <th>Статус</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var vacancy in Model.RecentVacancies)
                        {
                            var badgeClass = HrOptions.VacancyStatusBadge(vacancy.Status);

                            <tr>
                                <td>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                                    {
                                        <a asp-controller="Vacancies" asp-action="Details" asp-route-id="@vacancy.Id">@vacancy.Title</a>
                                    }
                                    else
                                    {
                                        @vacancy.Title
                                    }
                                    <div class="text-muted small">@vacancy.SalaryMin - @vacancy.SalaryMax</div>
                                </td>
                                <td><span class="badge @badgeClass">@vacancy.Status</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">Вакансій ще немає.</div>
            }
        </div>
    </div>
    <div class="col-xl-4">
        <div class="card h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h2 class="h5 mb-0">Найближчі співбесіди</h2>
                <a class="btn btn-sm btn-outline-secondary" asp-controller="Interviews" asp-action="Index">Усі</a>
            </div>
            @if (Model.UpcomingInterviews.Any())
            {
                <div class="list-group list-group-flush">
                @foreach (var interview in Model.UpcomingInterviews)
                {
                    <a class="list-group-item list-group-item-action" asp-controller="Interviews" asp-action="Details" asp-route-id="@interview.Id">
                        <div class="d-flex justify-content-between gap-2">
                            <strong>@interview.Application?.Candidate?.FullName</strong>
                            <span class="badge @HrOptions.InterviewResultBadge(interview.Result)">@interview.Result</span>
                        </div>
                        <div class="text-muted small">@interview.Application?.Vacancy?.Title</div>
                        <div class="small">@interview.InterviewDate.ToString("g") - @interview.InterviewType</div>
                        <div class="text-muted small">Рекрутер: @(interview.Recruiter?.FullName ?? "Не призначено")</div>
                    </a>
                }
                </div>
            }
            else
            {
                <div class="empty-state">Найближчих співбесід немає.</div>
            }
        </div>
    </div>
</div>
