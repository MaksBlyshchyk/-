@model InterviewFeedback

@{
    ViewData["Title"] = "Деталі відгуку";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2 mb-0">Відгук #@Model.Id</h1>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Редагувати</a>
        }
        <a class="btn btn-secondary" asp-action="Index">Назад до списку</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Кандидат</dt>
            <dd class="col-sm-9">@Model.Interview?.Application?.Candidate?.FullName</dd>
            <dt class="col-sm-3">Вакансія</dt>
            <dd class="col-sm-9">@Model.Interview?.Application?.Vacancy?.Title</dd>
            <dt class="col-sm-3">Автор відгуку</dt>
            <dd class="col-sm-9">@(Model.Recruiter?.FullName ?? "Не вказано")</dd>
            <dt class="col-sm-3">Оцінка</dt>
            <dd class="col-sm-9">@Model.Score/10</dd>
            <dt class="col-sm-3">Рекомендація</dt>
            <dd class="col-sm-9"><span class="badge @HrOptions.FeedbackRecommendationBadge(Model.Recommendation)">@Model.Recommendation</span></dd>
            <dt class="col-sm-3">Коментар</dt>
            <dd class="col-sm-9">@Model.Comment</dd>
            <dt class="col-sm-3">Створено</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>
        </dl>
    </div>
</div>
