@model IEnumerable<InterviewFeedback>

@{
    ViewData["Title"] = "Відгуки";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div>
        <h1 class="h2 mb-1">Відгуки після співбесід</h1>
        <p class="text-muted mb-0">Оцінки, рекомендації та коментарі інтерв'юерів із зазначенням автора.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create"><span aria-hidden="true">+</span> Додати відгук</a>
</div>

<div class="card">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Кандидат</th>
                        <th>Вакансія</th>
                        <th>Автор</th>
                        <th>Оцінка</th>
                        <th>Рекомендація</th>
                        <th>Створено</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    var badgeClass = item.Recommendation switch
                    {
                        "Hire" => "text-bg-success",
                        "Reserve" => "text-bg-info",
                        "Reject" => "text-bg-danger",
                        "Need more interviews" => "text-bg-warning",
                        _ => "text-bg-secondary"
                    };

                    <tr>
                        <td>@item.Interview?.Application?.Candidate?.FullName</td>
                        <td>@item.Interview?.Application?.Vacancy?.Title</td>
                        <td>@(item.Recruiter?.FullName ?? "Не вказано")</td>
                        <td><span class="badge text-bg-info">@item.Score/10</span></td>
                        <td><span class="badge @badgeClass">@item.Recommendation</span></td>
                        <td>@item.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td class="text-end text-nowrap">
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id"><span aria-hidden="true">E</span> Edit</a>
                            }
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id"><span aria-hidden="true">i</span> Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id"><span aria-hidden="true">x</span> Delete</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h2 class="h5">Відгуків ще немає</h2>
            <p class="text-muted mb-3">Додайте відгук після проведеної співбесіди.</p>
            <a class="btn btn-primary" asp-action="Create"><span aria-hidden="true">+</span> Додати відгук</a>
        </div>
    }
</div>
