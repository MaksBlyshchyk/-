@model IEnumerable<InterviewFeedback>

@{
    ViewData["Title"] = "Відгуки";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <h1 class="h2 mb-0">Відгуки після співбесід</h1>
    <a class="btn btn-primary" asp-action="Create">Додати відгук</a>
</div>

<div class="card">
    <div class="table-responsive">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Кандидат</th>
                <th>Вакансія</th>
                <th>Оцінка</th>
                <th>Рекомендація</th>
                <th>Створено</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Interview?.Application?.Candidate?.FullName</td>
                <td>@item.Interview?.Application?.Vacancy?.Title</td>
                <td><span class="badge text-bg-info">@item.Score/10</span></td>
                <td>@item.Recommendation</td>
                <td>@item.CreatedAt.ToLocalTime().ToString("g")</td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Редагувати</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Деталі</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Видалити</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
</div>
