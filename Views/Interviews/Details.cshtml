@model Interview

@{
    ViewData["Title"] = "Деталі співбесіди";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2 mb-0">Співбесіда #@Model.Id</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Редагувати</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Кандидат</dt>
    <dd class="col-sm-9">@Model.Application?.Candidate?.FullName</dd>
    <dt class="col-sm-3">Вакансія</dt>
    <dd class="col-sm-9">@Model.Application?.Vacancy?.Title</dd>
    <dt class="col-sm-3">Дата</dt>
    <dd class="col-sm-9">@Model.InterviewDate.ToString("g")</dd>
    <dt class="col-sm-3">Тип</dt>
    <dd class="col-sm-9">@Model.InterviewType</dd>
    <dt class="col-sm-3">Результат</dt>
    <dd class="col-sm-9">@Model.Result</dd>
    <dt class="col-sm-3">Нотатки</dt>
    <dd class="col-sm-9">@Model.Notes</dd>
</dl>

<h2 class="h5 mt-4">Відгуки</h2>
<table class="table table-sm align-middle">
    <thead>
        <tr>
            <th>Оцінка</th>
            <th>Рекомендація</th>
            <th>Коментар</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var feedback in Model.Feedbacks)
    {
        <tr>
            <td>@feedback.Score</td>
            <td>@feedback.Recommendation</td>
            <td>@feedback.Comment</td>
        </tr>
    }
    </tbody>
</table>
