@model IEnumerable<Interview>

@{
    ViewData["Title"] = "Співбесіди";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div>
        <h1 class="h2 mb-1">Співбесіди</h1>
        <p class="text-muted mb-0">Історія та план HR, технічних і фінальних співбесід із відповідальним рекрутером.</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
    {
        <a class="btn btn-success" asp-action="Create"><span aria-hidden="true">+</span> Запланувати співбесіду</a>
    }
</div>

<form asp-action="Index" method="get" class="card mb-3">
    <div class="card-body row g-3 align-items-end">
        <div class="col-sm-6 col-lg-3">
            <label class="form-label" for="interviewType">Тип</label>
            <select id="interviewType" class="form-select" name="interviewType" asp-items="ViewBag.InterviewTypes">
                <option value="">Усі типи</option>
            </select>
        </div>
        <div class="col-sm-6 col-lg-3">
            <label class="form-label" for="result">Результат</label>
            <select id="result" class="form-select" name="result" asp-items="ViewBag.Results">
                <option value="">Усі результати</option>
            </select>
        </div>
        <div class="col-sm-6 col-lg-3 d-flex gap-2">
            <button class="btn btn-outline-primary flex-fill" type="submit">Фільтрувати</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Скинути</a>
        </div>
    </div>
</form>

<div class="card">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Кандидат</th>
                        <th>Вакансія</th>
                        <th>Рекрутер</th>
                        <th>Дата</th>
                        <th>Тип</th>
                        <th>Результат</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    var badgeClass = HrOptions.InterviewResultBadge(item.Result);

                    <tr>
                        <td>@item.Application?.Candidate?.FullName</td>
                        <td>@item.Application?.Vacancy?.Title</td>
                        <td>@(item.Recruiter?.FullName ?? "Не призначено")</td>
                        <td>@item.InterviewDate.ToString("g")</td>
                        <td>@item.InterviewType</td>
                        <td><span class="badge @badgeClass">@item.Result</span></td>
                        <td class="text-end text-nowrap">
                            @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                            {
                                <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Id"><span aria-hidden="true">E</span> Редагувати</a>
                            }
                            <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id"><span aria-hidden="true">i</span> Деталі</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                            {
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id"><span aria-hidden="true">x</span> Видалити</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h2 class="h5">Дані відсутні</h2>
            <p class="text-muted mb-3">Натисніть кнопку «Додати», щоб створити перший запис.</p>
            @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
            {
                <a class="btn btn-success" asp-action="Create"><span aria-hidden="true">+</span> Запланувати співбесіду</a>
            }
        </div>
    }
</div>
