@model IEnumerable<Interview>

@{
    ViewData["Title"] = "Співбесіди";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div>
        <h1 class="h2 mb-1">Співбесіди</h1>
        <p class="text-muted mb-0">Історія та план найближчих HR, технічних і фінальних співбесід.</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
    {
        <a class="btn btn-primary" asp-action="Create"><span aria-hidden="true">+</span> Запланувати співбесіду</a>
    }
</div>

<div class="card">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Кандидат</th>
                        <th>Вакансія</th>
                        <th>Дата</th>
                        <th>Тип</th>
                        <th>Результат</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    var badgeClass = item.Result switch
                    {
                        "Planned" => "text-bg-primary",
                        "Passed" => "text-bg-success",
                        "Failed" => "text-bg-danger",
                        "Rescheduled" => "text-bg-warning",
                        _ => "text-bg-secondary"
                    };

                    <tr>
                        <td>@item.Application?.Candidate?.FullName</td>
                        <td>@item.Application?.Vacancy?.Title</td>
                        <td>@item.InterviewDate.ToString("g")</td>
                        <td>@item.InterviewType</td>
                        <td><span class="badge @badgeClass">@item.Result</span></td>
                        <td class="text-end text-nowrap">
                            @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id"><span aria-hidden="true">E</span> Edit</a>
                            }
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id"><span aria-hidden="true">i</span> Details</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                            {
                                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id"><span aria-hidden="true">x</span> Delete</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h2 class="h5">Співбесід ще немає</h2>
            <p class="text-muted mb-3">Створіть заявку і заплануйте співбесіду для кандидата.</p>
            @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
            {
                <a class="btn btn-primary" asp-action="Create"><span aria-hidden="true">+</span> Запланувати співбесіду</a>
            }
        </div>
    }
</div>
