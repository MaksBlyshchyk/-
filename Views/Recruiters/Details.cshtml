@model Recruiter

@{
    ViewData["Title"] = "Деталі рекрутера";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <h1 class="h2 mb-0">@Model.FullName</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Редагувати</a>
        <a class="btn btn-secondary" asp-action="Index">Назад до списку</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Електронна пошта</dt>
            <dd class="col-sm-9">@Model.Email</dd>
            <dt class="col-sm-3">Логін</dt>
            <dd class="col-sm-9"><code>@Model.Login</code></dd>
            <dt class="col-sm-3">Роль</dt>
            <dd class="col-sm-9"><span class="badge text-bg-primary">@Model.Role</span></dd>
            <dt class="col-sm-3">Створено</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>
        </dl>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Співбесіди</div>
                <div class="display-6 fw-semibold">@Model.Interviews.Count</div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Відгуки</div>
                <div class="display-6 fw-semibold">@Model.Feedbacks.Count</div>
            </div>
        </div>
    </div>
</div>
