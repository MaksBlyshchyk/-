@model IEnumerable<Recruiter>

@{
    ViewData["Title"] = "Рекрутери";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div>
        <h1 class="h2 mb-1">Рекрутери</h1>
        <p class="text-muted mb-0">Користувачі системи, ролі та відповідальні за співбесіди й відгуки.</p>
    </div>
    <a class="btn btn-success" asp-action="Create"><span aria-hidden="true">+</span> Додати рекрутера</a>
</div>

<div class="card">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ПІБ</th>
                        <th>Електронна пошта</th>
                        <th>Логін</th>
                        <th>Роль</th>
                        <th>Створено</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    var badgeClass = item.Role switch
                    {
                        "Admin" => "text-bg-danger",
                        "Recruiter" => "text-bg-primary",
                        "Interviewer" => "text-bg-info",
                        _ => "text-bg-secondary"
                    };

                    <tr>
                        <td class="fw-semibold">@item.FullName</td>
                        <td>@item.Email</td>
                        <td><code>@item.Login</code></td>
                        <td><span class="badge @badgeClass">@item.Role</span></td>
                        <td>@item.CreatedAt.ToLocalTime().ToString("d")</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Id"><span aria-hidden="true">E</span> Редагувати</a>
                            <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id"><span aria-hidden="true">i</span> Деталі</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id"><span aria-hidden="true">x</span> Видалити</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h2 class="h5">Рекрутерів ще немає</h2>
            <p class="text-muted mb-3">Додайте користувача для роботи з HR-системою.</p>
            <a class="btn btn-success" asp-action="Create"><span aria-hidden="true">+</span> Додати рекрутера</a>
        </div>
    }
</div>
