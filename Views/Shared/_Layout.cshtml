<!DOCTYPE html>
<html lang="uk" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HR Reserve System</title>
    <script>
        (function () {
            try {
                var savedTheme = localStorage.getItem("hrreserve-theme");
                document.documentElement.setAttribute("data-theme", savedTheme === "light" ? "light" : "dark");
            } catch (error) {
                document.documentElement.setAttribute("data-theme", "dark");
            }
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HRReserveSystem.styles.css" asp-append-version="true" />
</head>
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var canRecruit = User.IsInRole("Admin") || User.IsInRole("Recruiter");
    var canInterview = User.IsInRole("Admin") || User.IsInRole("Interviewer");
    var isAdmin = User.IsInRole("Admin");
    var displayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "Користувач";
    var displayInitial = string.IsNullOrWhiteSpace(displayName) ? "H" : displayName.Trim()[0].ToString().ToUpperInvariant();
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var shellClass = isAuthenticated ? "has-auth-shell" : "public-shell";
    Func<string, string, string> activeClass = (controller, action) =>
        currentController == controller && (string.IsNullOrEmpty(action) || currentAction == action) ? "active" : "";
}
<body data-theme="dark" class="@shellClass">
    <div class="app-shell">
        @if (isAuthenticated)
        {
            <aside class="app-sidebar d-none d-lg-flex" aria-label="Основна навігація">
                <a class="sidebar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="sidebar-logo" aria-hidden="true">HR</span>
                    <span>
                        <strong>HR Reserve</strong>
                        <small>Кадровий резерв</small>
                    </span>
                </a>

                <nav class="sidebar-nav">
                    <a class="sidebar-link @(activeClass("Home", "Index"))" asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="sidebar-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 4h7v7H4zM13 4h7v7h-7zM4 13h7v7H4zM13 13h7v7h-7z" /></svg></span>
                        <span>Dashboard</span>
                    </a>
                    @if (canRecruit)
                    {
                        <a class="sidebar-link @(activeClass("Candidates", ""))" asp-area="" asp-controller="Candidates" asp-action="Index">
                            <span class="sidebar-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm7 8a7 7 0 0 0-14 0" /></svg></span>
                            <span>Кандидати</span>
                        </a>
                        <a class="sidebar-link @(activeClass("Vacancies", ""))" asp-area="" asp-controller="Vacancies" asp-action="Index">
                            <span class="sidebar-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M9 7V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2m-9 0h12v12H4V7h4Zm0 5h8" /></svg></span>
                            <span>Вакансії</span>
                        </a>
                        <a class="sidebar-link @(activeClass("Applications", ""))" asp-area="" asp-controller="Applications" asp-action="Index">
                            <span class="sidebar-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7 3h7l4 4v14H7zM14 3v5h5M9 13h6M9 17h6" /></svg></span>
                            <span>Заявки</span>
                        </a>
                    }
                    <a class="sidebar-link @(activeClass("Interviews", ""))" asp-area="" asp-controller="Interviews" asp-action="Index">
                        <span class="sidebar-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M7 4v3m10-3v3M5 8h14M5 5h14v15H5zM8 12h3m3 0h2M8 16h5" /></svg></span>
                        <span>Співбесіди</span>
                    </a>
                    @if (canInterview)
                    {
                        <a class="sidebar-link @(activeClass("InterviewFeedbacks", ""))" asp-area="" asp-controller="InterviewFeedbacks" asp-action="Index">
                            <span class="sidebar-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 5h14v10H8l-3 4V5Zm4 4h6m-6 4h4" /></svg></span>
                            <span>Відгуки</span>
                        </a>
                        <a class="sidebar-link @(activeClass("SoftSkillAssessments", ""))" asp-area="" asp-controller="SoftSkillAssessments" asp-action="Index">
                            <span class="sidebar-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="m12 3 2.7 5.5 6.1.9-4.4 4.3 1 6-5.4-2.9-5.4 2.9 1-6-4.4-4.3 6.1-.9z" /></svg></span>
                            <span>Soft Skills</span>
                        </a>
                    }
                    @if (isAdmin)
                    {
                        <a class="sidebar-link @(activeClass("Recruiters", ""))" asp-area="" asp-controller="Recruiters" asp-action="Index">
                            <span class="sidebar-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm6-1a3 3 0 1 0 0-6M3 20a6 6 0 0 1 12 0m3 0a6 6 0 0 0-3-5.2" /></svg></span>
                            <span>Рекрутери</span>
                        </a>
                    }
                    <a class="sidebar-link @(activeClass("Home", "About"))" asp-area="" asp-controller="Home" asp-action="About">
                        <span class="sidebar-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 17v-5m0-4h.01M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" /></svg></span>
                        <span>Про систему</span>
                    </a>
                </nav>

                <div class="sidebar-footer">
                    <div class="sidebar-profile">
                        <div class="profile-avatar" aria-hidden="true">@displayInitial</div>
                        <div class="min-w-0">
                            <div class="text-truncate fw-semibold">@displayName</div>
                            <span class="badge @HrOptions.RecruiterRoleBadge(role)">@role</span>
                        </div>
                    </div>
                    <a class="btn btn-outline-danger w-100" asp-controller="Account" asp-action="Logout">Вийти</a>
                </div>
            </aside>
        }

        <div class="app-content">
            <header class="app-topbar">
                <div class="d-flex align-items-center gap-3 min-w-0">
                    @if (isAuthenticated)
                    {
                        <button class="btn btn-icon d-none d-lg-inline-flex" type="button" data-sidebar-toggle aria-expanded="true" aria-label="Згорнути меню">
                            <span aria-hidden="true">☰</span>
                        </button>
                        <button class="btn btn-icon d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu" aria-controls="mobileMenu" aria-label="Відкрити меню">
                            <span aria-hidden="true">☰</span>
                        </button>
                    }
                    <a class="topbar-brand d-lg-none" asp-area="" asp-controller="Home" asp-action="Index">HR Reserve</a>
                </div>

                @if (isAuthenticated && canRecruit)
                {
                    <form class="topbar-search d-none d-xl-flex" role="search" asp-controller="Candidates" asp-action="Index" method="get" data-global-search>
                        <span aria-hidden="true"><svg viewBox="0 0 24 24"><path d="m21 21-4.3-4.3M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" /></svg></span>
                        <input type="search" class="form-control" name="search" placeholder="Пошук кандидата, вакансії або заявки" aria-label="Пошук" />
                    </form>
                }

                <div class="topbar-actions">
                    @if (isAuthenticated)
                    {
                        <div class="app-dropdown" data-dropdown>
                            <button class="btn btn-sm btn-icon btn-notification" type="button" aria-label="Сповіщення" aria-expanded="false" data-dropdown-toggle data-notification-toggle>
                                <span aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9M10 21h4" /></svg></span>
                                <span class="notification-dot" data-notification-dot></span>
                            </button>
                            <div class="app-dropdown-menu notification-menu" data-dropdown-menu>
                                <div class="dropdown-title">Повідомлення</div>
                                <div class="notification-list" data-notification-list>
                                    <div class="notification-item">
                                        <strong>Найближча співбесіда сьогодні</strong>
                                        <span>Перевірте розклад у розділі співбесід.</span>
                                    </div>
                                    <div class="notification-item">
                                        <strong>Додано нового кандидата</strong>
                                        <span>Оновіть список кандидатів для перегляду.</span>
                                    </div>
                                    <div class="notification-item">
                                        <strong>Є заявки зі статусом Interview</strong>
                                        <span>Потрібна увага рекрутера або інтерв'юера.</span>
                                    </div>
                                </div>
                                <div class="notification-empty d-none" data-notification-empty>Нових повідомлень немає</div>
                            </div>
                        </div>
                    }
                    <button class="btn btn-sm btn-theme-toggle" type="button" data-theme-toggle aria-label="Перемкнути тему" aria-pressed="false">
                        <span class="theme-toggle-icon" aria-hidden="true">🌙</span>
                        <span class="theme-toggle-text">Темна</span>
                    </button>
                    @if (isAuthenticated)
                    {
                        <div class="app-dropdown d-none d-md-block" data-dropdown>
                            <button class="navbar-text small app-user-chip profile-button" type="button" aria-expanded="false" data-dropdown-toggle>
                                <span class="profile-avatar topbar-avatar" aria-hidden="true">@displayInitial</span>
                                <span class="profile-copy">
                                    <span class="profile-name">@displayName</span>
                                    <span class="profile-role">@role</span>
                                </span>
                                <span class="profile-caret" aria-hidden="true">⌄</span>
                            </button>
                            <div class="app-dropdown-menu profile-menu" data-dropdown-menu>
                                <div class="profile-menu-head">
                                    <span class="profile-avatar" aria-hidden="true">@displayInitial</span>
                                    <span>
                                        <strong>@displayName</strong>
                                        <small>@role</small>
                                    </span>
                                </div>
                                <a class="dropdown-item-soft dropdown-item-danger" asp-controller="Account" asp-action="Logout">Вийти</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="Home" asp-action="About">Про систему</a>
                        <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Login">Увійти</a>
                    }
                </div>
            </header>

            <main role="main" class="container-fluid app-container app-main">
                @RenderBody()
            </main>

            <footer class="border-top footer text-muted app-footer">
                <div class="container-fluid app-container">
                    &copy; 2026 - HR Reserve System - <a asp-area="" asp-controller="Home" asp-action="About">Про систему</a>
                </div>
            </footer>
        </div>
    </div>

    @if (isAuthenticated)
    {
        <div class="offcanvas offcanvas-start app-offcanvas" tabindex="-1" id="mobileMenu" aria-labelledby="mobileMenuLabel">
            <div class="offcanvas-header">
                <div>
                    <h2 class="offcanvas-title h5" id="mobileMenuLabel">HR Reserve</h2>
                    <div class="small text-muted">@displayName · @role</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Закрити"></button>
            </div>
            <div class="offcanvas-body d-flex flex-column">
                <nav class="sidebar-nav flex-grow-1">
                    <a class="sidebar-link @(activeClass("Home", "Index"))" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                    @if (canRecruit)
                    {
                        <a class="sidebar-link @(activeClass("Candidates", ""))" asp-area="" asp-controller="Candidates" asp-action="Index">Кандидати</a>
                        <a class="sidebar-link @(activeClass("Vacancies", ""))" asp-area="" asp-controller="Vacancies" asp-action="Index">Вакансії</a>
                        <a class="sidebar-link @(activeClass("Applications", ""))" asp-area="" asp-controller="Applications" asp-action="Index">Заявки</a>
                    }
                    <a class="sidebar-link @(activeClass("Interviews", ""))" asp-area="" asp-controller="Interviews" asp-action="Index">Співбесіди</a>
                    @if (canInterview)
                    {
                        <a class="sidebar-link @(activeClass("InterviewFeedbacks", ""))" asp-area="" asp-controller="InterviewFeedbacks" asp-action="Index">Відгуки</a>
                        <a class="sidebar-link @(activeClass("SoftSkillAssessments", ""))" asp-area="" asp-controller="SoftSkillAssessments" asp-action="Index">Soft Skills</a>
                    }
                    @if (isAdmin)
                    {
                        <a class="sidebar-link @(activeClass("Recruiters", ""))" asp-area="" asp-controller="Recruiters" asp-action="Index">Рекрутери</a>
                    }
                    <a class="sidebar-link @(activeClass("Home", "About"))" asp-area="" asp-controller="Home" asp-action="About">Про систему</a>
                </nav>
                <button class="btn btn-theme-toggle w-100 mb-2" type="button" data-theme-toggle aria-label="Перемкнути тему">
                    <span class="theme-toggle-icon" aria-hidden="true">🌙</span>
                    <span class="theme-toggle-text">Темна</span>
                </button>
                <a class="btn btn-outline-danger w-100" asp-controller="Account" asp-action="Logout">Вийти</a>
            </div>
        </div>

        <nav class="mobile-bottom-nav d-md-none" aria-label="Швидка мобільна навігація">
            <a class="@(activeClass("Home", "Index"))" asp-area="" asp-controller="Home" asp-action="Index">
                <span aria-hidden="true">▦</span>
                <small>Dashboard</small>
            </a>
            @if (canRecruit)
            {
                <a class="@(activeClass("Candidates", ""))" asp-area="" asp-controller="Candidates" asp-action="Index">
                    <span aria-hidden="true">К</span>
                    <small>Кандидати</small>
                </a>
                <a class="@(activeClass("Vacancies", ""))" asp-area="" asp-controller="Vacancies" asp-action="Index">
                    <span aria-hidden="true">В</span>
                    <small>Вакансії</small>
                </a>
            }
            else
            {
                <a class="@(activeClass("Interviews", ""))" asp-area="" asp-controller="Interviews" asp-action="Index">
                    <span aria-hidden="true">С</span>
                    <small>Співбесіди</small>
                </a>
                <a class="@(activeClass("InterviewFeedbacks", ""))" asp-area="" asp-controller="InterviewFeedbacks" asp-action="Index">
                    <span aria-hidden="true">Вд</span>
                    <small>Відгуки</small>
                </a>
            }
            <button type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu" aria-controls="mobileMenu">
                <span aria-hidden="true">⋯</span>
                <small>Ще</small>
            </button>
        </nav>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
