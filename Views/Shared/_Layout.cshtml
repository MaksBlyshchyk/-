<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HR Reserve System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HRReserveSystem.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">HR Reserve</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-lg-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark @(currentController == "Home" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                            </li>
                            @if (User.IsInRole("Admin") || User.IsInRole("Recruiter"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentController == "Candidates" ? "active" : "")" asp-area="" asp-controller="Candidates" asp-action="Index">Кандидати</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentController == "Vacancies" ? "active" : "")" asp-area="" asp-controller="Vacancies" asp-action="Index">Вакансії</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentController == "Applications" ? "active" : "")" asp-area="" asp-controller="Applications" asp-action="Index">Заявки</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link text-dark @(currentController == "Interviews" ? "active" : "")" asp-area="" asp-controller="Interviews" asp-action="Index">Співбесіди</a>
                            </li>
                            @if (User.IsInRole("Admin") || User.IsInRole("Interviewer"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentController == "InterviewFeedbacks" ? "active" : "")" asp-area="" asp-controller="InterviewFeedbacks" asp-action="Index">Відгуки</a>
                                </li>
                            }
                            @if (User.IsInRole("Admin") || User.IsInRole("Interviewer"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentController == "SoftSkillAssessments" ? "active" : "")" asp-area="" asp-controller="SoftSkillAssessments" asp-action="Index">Soft Skills</a>
                                </li>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentController == "Recruiters" ? "active" : "")" asp-area="" asp-controller="Recruiters" asp-action="Index">Рекрутери</a>
                                </li>
                            }
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="About">Про систему</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-lg-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item me-lg-2">
                                <span class="navbar-text small">
                                    @User.FindFirst("DisplayName")?.Value
                                    <span class="badge text-bg-primary ms-1">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-outline-danger" asp-controller="Account" asp-action="Logout">Вийти</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Login">Увійти</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid app-container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white">
        <div class="container-fluid">
            &copy; 2026 - HR Reserve System - <a asp-area="" asp-controller="Home" asp-action="About">Про систему</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
