@model SoftSkillAssessment

@{
    ViewData["Title"] = "Видалити soft skills";
}

<h1 class="h2 mb-3">Видалити оцінку soft skills</h1>
<div class="alert alert-warning">Підтвердіть видалення оцінки кандидата <strong>@Model.Candidate?.FullName</strong>.</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Видалити</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
</form>
