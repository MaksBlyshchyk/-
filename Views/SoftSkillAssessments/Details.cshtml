@model SoftSkillAssessment

@{
    ViewData["Title"] = "Деталі soft skills";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h2 mb-0">@Model.Candidate?.FullName</h1>
    <div class="d-flex gap-2">
        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Редагувати</a>
        <a class="btn btn-secondary" asp-action="Index">Назад до списку</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Комунікація</dt>
    <dd class="col-sm-9"><span class="score-badge">@Model.Communication</span> <span class="text-muted">/ 10</span></dd>
    <dt class="col-sm-3">Командна робота</dt>
    <dd class="col-sm-9"><span class="score-badge">@Model.Teamwork</span> <span class="text-muted">/ 10</span></dd>
    <dt class="col-sm-3">Відповідальність</dt>
    <dd class="col-sm-9"><span class="score-badge">@Model.Responsibility</span> <span class="text-muted">/ 10</span></dd>
    <dt class="col-sm-3">Стресостійкість</dt>
    <dd class="col-sm-9"><span class="score-badge">@Model.StressResistance</span> <span class="text-muted">/ 10</span></dd>
    <dt class="col-sm-3">Лідерство</dt>
    <dd class="col-sm-9"><span class="score-badge">@Model.Leadership</span> <span class="text-muted">/ 10</span></dd>
    <dt class="col-sm-3">Середній бал</dt>
    <dd class="col-sm-9"><span class="score-badge score-badge-average">@Model.AverageScore</span> <span class="text-muted">/ 10</span></dd>
    <dt class="col-sm-3">Коментар</dt>
    <dd class="col-sm-9">@Model.OverallComment</dd>
</dl>
