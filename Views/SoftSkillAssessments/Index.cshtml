@model IEnumerable<SoftSkillAssessment>

@{
    ViewData["Title"] = "Soft Skills";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div>
        <h1 class="h2 mb-1">Оцінки soft skills</h1>
        <p class="text-muted mb-0">Комунікація, командна робота, відповідальність, стресостійкість і лідерство кандидатів.</p>
    </div>
    <a class="btn btn-success" asp-action="Create"><span aria-hidden="true">+</span> Додати оцінку</a>
</div>

<div class="card">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Кандидат</th>
                        <th>Комунікація</th>
                        <th>Команда</th>
                        <th>Відповідальність</th>
                        <th>Стрес</th>
                        <th>Лідерство</th>
                        <th>Середній бал</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Candidate?.FullName</td>
                        <td><span class="score-badge">@item.Communication</span></td>
                        <td><span class="score-badge">@item.Teamwork</span></td>
                        <td><span class="score-badge">@item.Responsibility</span></td>
                        <td><span class="score-badge">@item.StressResistance</span></td>
                        <td><span class="score-badge">@item.Leadership</span></td>
                        <td><span class="score-badge score-badge-average">@item.AverageScore</span></td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Id"><span aria-hidden="true">E</span> Редагувати</a>
                            <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-id="@item.Id"><span aria-hidden="true">i</span> Деталі</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id"><span aria-hidden="true">x</span> Видалити</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h2 class="h5">Оцінок soft skills ще немає</h2>
            <p class="text-muted mb-3">Додайте оцінку кандидата для кадрового резерву.</p>
            <a class="btn btn-success" asp-action="Create"><span aria-hidden="true">+</span> Додати оцінку</a>
        </div>
    }
</div>
