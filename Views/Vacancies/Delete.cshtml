@model Vacancy

@{
    ViewData["Title"] = "Видалити вакансію";
}

<h1 class="h2 mb-3">Видалити вакансію</h1>
<div class="alert alert-warning">Підтвердіть видалення вакансії <strong>@Model.Title</strong>.</div>

<dl class="row">
    <dt class="col-sm-3">Статус</dt>
    <dd class="col-sm-9">@Model.Status</dd>
    <dt class="col-sm-3">Зарплата</dt>
    <dd class="col-sm-9">@Model.SalaryMin - @Model.SalaryMax</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Видалити</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
</form>
