@model Vacancy

@{
    ViewData["Title"] = "Деталі вакансії";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h2 mb-1">@Model.Title</h1>
        <span class="badge @HrOptions.VacancyStatusBadge(Model.Status)">@Model.Status</span>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Редагувати</a>
        <a class="btn btn-secondary" asp-action="Index">Назад до списку</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Опис</dt>
    <dd class="col-sm-9">@Model.Description</dd>
    <dt class="col-sm-3">Вимоги</dt>
    <dd class="col-sm-9">@Model.Requirements</dd>
    <dt class="col-sm-3">Зарплата</dt>
    <dd class="col-sm-9">@Model.SalaryMin - @Model.SalaryMax</dd>
    <dt class="col-sm-3">Створено</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("g")</dd>
</dl>

<h2 class="h5 mt-4">Заявки на вакансію</h2>
@if (Model.Applications.Any())
{
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>Кандидат</th>
                <th>Статус</th>
                <th>Дата</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var application in Model.Applications)
        {
            <tr>
                <td>@application.Candidate?.FullName</td>
                <td><span class="badge @HrOptions.ApplicationStatusBadge(application.Status)">@application.Status</span></td>
                <td>@application.AppliedAt.ToLocalTime().ToString("g")</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <div class="empty-state">На цю вакансію ще немає заявок.</div>
}
