@model IEnumerable<Vacancy>

@{
    ViewData["Title"] = "Вакансії";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <h1 class="h2 mb-0">Вакансії</h1>
    <a class="btn btn-primary" asp-action="Create">Додати вакансію</a>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input class="form-control" type="search" name="search" value="@ViewData["CurrentFilter"]" placeholder="Пошук за назвою, описом або вимогами" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" type="submit">Пошук</button>
    </div>
</form>

<div class="card">
    <div class="table-responsive">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Назва</th>
                <th>Статус</th>
                <th>Зарплата</th>
                <th>Створено</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            var badgeClass = item.Status switch
            {
                "Open" => "text-bg-success",
                "Paused" => "text-bg-warning",
                "Closed" => "text-bg-secondary",
                _ => "text-bg-primary"
            };

            <tr>
                <td>@item.Title</td>
                <td><span class="badge @badgeClass">@item.Status</span></td>
                <td>@item.SalaryMin - @item.SalaryMax</td>
                <td>@item.CreatedAt.ToLocalTime().ToString("d")</td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Редагувати</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Деталі</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Видалити</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
</div>
